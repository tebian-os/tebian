# Material Theme - Mako Notifications
font=JetBrainsMono Nerd Font 11

# Material Palenight Colors
background-color=#292D3E
text-color=#A6ACCD
border-color=#82AAFF

# Layout
border-radius=10
border-size=2
default-timeout=5000
max-visible=3
anchor=top-right
margin=8
padding=12
width=350

# Icons
icons=1
max-icon-size=48

# Show over fullscreen windows
layer=overlay

# Group duplicate notifications
group-by=summary
format=<b>%s</b>\n%b

# Urgent notifications
[urgency=critical]
border-color=#F07178
default-timeout=0

[urgency=low]
border-color=#3A3F5C
default-timeout=3000

# Rose Pine Theme - Mako Notifications
font=JetBrainsMono Nerd Font 11

# Rose Pine Colors
background-color=#191724
text-color=#E0DEF4
border-color=#EB6F92

# Layout
border-radius=10
border-size=2
default-timeout=5000
max-visible=3
anchor=top-right
margin=8
padding=12
width=350

# Icons
icons=1
max-icon-size=48

# Show over fullscreen windows
layer=overlay

# Group duplicate notifications
group-by=summary
format=<b>%s</b>\n%b

# Urgent notifications
[urgency=critical]
border-color=#EB6F92
default-timeout=0

[urgency=low]
border-color=#26233A
default-timeout=3000

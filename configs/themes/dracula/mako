# Dracula Theme - Mako Notifications
font=JetBrainsMono Nerd Font 11

# Dracula Colors
background-color=#282A36
text-color=#F8F8F2
border-color=#BD93F9

# Layout
border-radius=10
border-size=2
default-timeout=5000
max-visible=3
anchor=top-right
margin=8
padding=12
width=350

# Icons
icons=1
max-icon-size=48

# Show over fullscreen windows
layer=overlay

# Group duplicate notifications
group-by=summary
format=<b>%s</b>\n%b

# Urgent notifications
[urgency=critical]
border-color=#FF5555
default-timeout=0

[urgency=low]
border-color=#44475A
default-timeout=3000

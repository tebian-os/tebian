# Everforest Theme - Mako Notifications
font=JetBrainsMono Nerd Font 11

# Everforest Colors
background-color=#2D353B
text-color=#D3C6AA
border-color=#A7C080

# Layout
border-radius=10
border-size=2
default-timeout=5000
max-visible=3
anchor=top-right
margin=8
padding=12
width=350

# Icons
icons=1
max-icon-size=48

# Show over fullscreen windows
layer=overlay

# Group duplicate notifications
group-by=summary
format=<b>%s</b>\n%b

# Urgent notifications
[urgency=critical]
border-color=#E67E80
default-timeout=0

[urgency=low]
border-color=#3D484D
default-timeout=3000

# Nord Theme - Mako Notifications
font=JetBrainsMono Nerd Font 11

# Nord Colors
background-color=#2E3440
text-color=#ECEFF4
border-color=#5E81AC

# Layout
border-radius=10
border-size=2
default-timeout=5000
max-visible=3
anchor=top-right
margin=8
padding=12
width=350

# Icons
icons=1
max-icon-size=48

# Show over fullscreen windows
layer=overlay

# Group duplicate notifications
group-by=summary
format=<b>%s</b>\n%b

# Urgent notifications
[urgency=critical]
border-color=#BF616A
default-timeout=0

[urgency=low]
border-color=#434C5E
default-timeout=3000

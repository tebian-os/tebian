# Tokyo Night Theme - Mako Notifications
font=JetBrainsMono Nerd Font 11

# Tokyo Night Colors
background-color=#1A1B26
text-color=#C0CAF5
border-color=#7AA2F7

# Layout
border-radius=10
border-size=2
default-timeout=5000
max-visible=3
anchor=top-right
margin=8
padding=12
width=350

# Icons
icons=1
max-icon-size=48

# Show over fullscreen windows
layer=overlay

# Group duplicate notifications
group-by=summary
format=<b>%s</b>\n%b

# Urgent notifications
[urgency=critical]
border-color=#F7768E
default-timeout=0

[urgency=low]
border-color=#292E42
default-timeout=3000

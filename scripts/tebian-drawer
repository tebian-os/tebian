#!/bin/bash
# ==============================================================================
# TEBIAN APP DRAWER (Mod+A)
# Browse all installed apps. Pin/unpin apps to the main menu.
# ==============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/tebian-common" ]; then
    source "$SCRIPT_DIR/tebian-common"
elif [ -f "$HOME/.local/bin/tebian-common" ]; then
    source "$HOME/.local/bin/tebian-common"
fi

PIN_FILE="$HOME/.config/tebian/pinned-apps.conf"
DESKTOP_DIRS="/usr/share/applications $HOME/.local/share/applications /var/lib/flatpak/exports/share/applications $HOME/.local/share/flatpak/exports/share/applications"

mkdir -p "$HOME/.config/tebian"
[ -f "$PIN_FILE" ] || touch "$PIN_FILE"

is_pinned() {
    grep -qxF "$1" "$PIN_FILE" 2>/dev/null
}

# Edit Pins mode â€” show all apps with pin status, toggle on select
edit_pins() {
    while true; do
        local MENU=""
        declare -A SEEN=()
        declare -A NAME_TO_DESKTOP=()

        for dir in $DESKTOP_DIRS; do
            [ -d "$dir" ] || continue
            for desktop in "$dir"/*.desktop; do
                [ -f "$desktop" ] || continue
                grep -q "^NoDisplay=true" "$desktop" 2>/dev/null && continue
                grep -q "^Hidden=true" "$desktop" 2>/dev/null && continue
                local tryexec
                tryexec=$(grep -m1 "^TryExec=" "$desktop" | cut -d= -f2-)
                [ -n "$tryexec" ] && ! command -v "$tryexec" &>/dev/null && continue

                local name bname
                name=$(grep -m1 "^Name=" "$desktop" | cut -d= -f2-)
                bname=$(basename "$desktop")
                [ -z "$name" ] && continue
                [ -n "${SEEN[$name]}" ] && continue
                SEEN[$name]=1
                NAME_TO_DESKTOP[$name]="$bname"

                if is_pinned "$bname"; then
                    MENU+="[pinned] $name\n"
                else
                    MENU+="[     ] $name\n"
                fi
            done
        done

        local SORTED
        SORTED=$(echo -e "$MENU" | sort -t']' -k2)

        local PICK
        PICK=$(echo -e "َ°Œچ Back\n$SORTED" | tfuzzel -d -p " ًں“Œ Edit Menu | " --width 40)

        if [[ "$PICK" =~ "Back" || -z "$PICK" ]]; then
            # Re-launch the drawer when leaving edit mode
            exec tebian-drawer
        fi

        # Extract app name (strip bracket prefix)
        local app_name
        app_name=$(echo "$PICK" | sed 's/^\[.*\] //')

        # Look up .desktop file from our map
        local bname="${NAME_TO_DESKTOP[$app_name]}"

        if [ -n "$bname" ]; then
            if is_pinned "$bname"; then
                grep -vxF "$bname" "$PIN_FILE" > "$PIN_FILE.tmp"
                mv "$PIN_FILE.tmp" "$PIN_FILE"
                notify-send "Menu" "Unpinned: $app_name" 2>/dev/null
            else
                echo "$bname" >> "$PIN_FILE"
                notify-send "Menu" "Pinned: $app_name" 2>/dev/null
            fi
        fi
        # Loop continues â€” re-shows edit menu with updated pin status
    done
}

# Main drawer â€” collect apps as "name|icon" pairs, sort by name, then format for fuzzel
declare -A SEEN
ENTRIES=()

for dir in $DESKTOP_DIRS; do
    [ -d "$dir" ] || continue
    for desktop in "$dir"/*.desktop; do
        [ -f "$desktop" ] || continue
        grep -q "^NoDisplay=true" "$desktop" 2>/dev/null && continue
        grep -q "^Hidden=true" "$desktop" 2>/dev/null && continue
        tryexec=$(grep -m1 "^TryExec=" "$desktop" | cut -d= -f2-)
        [ -n "$tryexec" ] && ! command -v "$tryexec" &>/dev/null && continue

        name=$(grep -m1 "^Name=" "$desktop" | cut -d= -f2-)
        [ -z "$name" ] && continue
        [ -n "${SEEN[$name]}" ] && continue
        SEEN[$name]=1

        icon=$(grep -m1 "^Icon=" "$desktop" | cut -d= -f2-)
        ENTRIES+=("$name|$icon")
    done
done

# Sort entries by name
IFS=$'\n' SORTED=($(printf '%s\n' "${ENTRIES[@]}" | sort -f)); unset IFS

# Build fuzzel menu: Edit Menu first, sorted apps, Back last
MENU="َ°ڈ« Edit Menu\n"
for entry in "${SORTED[@]}"; do
    ename="${entry%%|*}"
    eicon="${entry#*|}"
    if [ -n "$eicon" ]; then
        MENU+="${ename}\0icon\x1f${eicon}\n"
    else
        MENU+="${ename}\n"
    fi
done
MENU+="َ°Œچ Back"

CHOICE=$(echo -e "$MENU" | tfuzzel -d -p " ًں“‚ Apps | " --width 40)

if [ -z "$CHOICE" ]; then
    tebian-menu &
    exit 0
fi

if [[ "$CHOICE" =~ "Back" ]]; then
    tebian-menu &
    exit 0
fi

if [[ "$CHOICE" =~ "Edit Menu" ]]; then
    edit_pins
    exit 0
fi

# Find and launch the selected app
CHOICE=$(echo "$CHOICE" | xargs)  # trim whitespace
for dir in $DESKTOP_DIRS; do
    [ -d "$dir" ] || continue
    for desktop in "$dir"/*.desktop; do
        [ -f "$desktop" ] || continue
        if grep -qxF "Name=$CHOICE" "$desktop" 2>/dev/null; then
            # Use gtk-launch for reliable .desktop launching, fall back to swaymsg exec
            bname=$(basename "$desktop" .desktop)
            gtk-launch "$bname" 2>/dev/null || {
                exec_cmd=$(grep -m1 "^Exec=" "$desktop" | cut -d= -f2- | sed 's/ %[fFuUdDnNickvm]//g')
                swaymsg exec -- "$exec_cmd"
            }
            exit 0
        fi
    done
done

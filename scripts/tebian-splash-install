#!/bin/bash
# Tebian Splash Screen Installer (v2.0)
# Installs the custom Tebian Plymouth boot splash theme

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEBIAN_SRC="${SCRIPT_DIR%/scripts}"
ASSETS_DIR="$TEBIAN_SRC/assets/plymouth/tebian"
THEME_DIR="/usr/share/plymouth/themes/tebian"

if [ ! -f "$ASSETS_DIR/tebian.plymouth" ] || [ ! -f "$ASSETS_DIR/tebian.script" ]; then
    echo "Error: Theme assets not found in $ASSETS_DIR"
    exit 1
fi

echo "Installing Tebian Plymouth theme..."

# Copy theme files
sudo mkdir -p "$THEME_DIR"
sudo cp "$ASSETS_DIR/tebian.plymouth" "$THEME_DIR/"
sudo cp "$ASSETS_DIR/tebian.script" "$THEME_DIR/"

# Set as default and rebuild initramfs
PLYMOUTH_BIN="/usr/sbin/plymouth-set-default-theme"
if [ ! -x "$PLYMOUTH_BIN" ]; then
    echo "Warning: plymouth-set-default-theme not found. Install plymouth first."
    exit 1
fi
sudo "$PLYMOUTH_BIN" -R tebian
echo "Tebian splash theme applied (initramfs updated)"

#!/bin/bash
export PATH="$HOME/.local/bin:$PATH"
# ==============================================================================
# TEBIAN MAIN MENU (Mod+D)
# Shows pinned apps + system entries. Pin/unpin from the App Drawer.
# ==============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/tebian-common" ]; then
    source "$SCRIPT_DIR/tebian-common"
elif [ -f "$HOME/.local/bin/tebian-common" ]; then
    source "$HOME/.local/bin/tebian-common"
fi

PIN_FILE="$HOME/.config/tebian/pinned-apps.conf"
DESKTOP_DIRS="/usr/share/applications $HOME/.local/share/applications /var/lib/flatpak/exports/share/applications $HOME/.local/share/flatpak/exports/share/applications"

# Create default pins on first run
if [ ! -f "$PIN_FILE" ]; then
    mkdir -p "$HOME/.config/tebian"
    cat > "$PIN_FILE" << 'EOF'
firefox-esr.desktop
firefox.desktop
chromium.desktop
org.mozilla.firefox.desktop
kitty.desktop
thunar.desktop
code.desktop
EOF
fi

# Resolve a .desktop file to Name and Icon
resolve_desktop() {
    local basename="$1"
    for dir in $DESKTOP_DIRS; do
        local f="$dir/$basename"
        [ -f "$f" ] || continue
        # Skip NoDisplay/Hidden
        grep -q "^NoDisplay=true" "$f" 2>/dev/null && return 1
        grep -q "^Hidden=true" "$f" 2>/dev/null && return 1
        # Check TryExec
        local tryexec
        tryexec=$(grep -m1 "^TryExec=" "$f" | cut -d= -f2-)
        [ -n "$tryexec" ] && ! command -v "$tryexec" &>/dev/null && return 1
        local name icon
        name=$(grep -m1 "^Name=" "$f" | cut -d= -f2-)
        icon=$(grep -m1 "^Icon=" "$f" | cut -d= -f2-)
        [ -z "$name" ] && return 1
        echo "$name|$icon|$basename"
        return 0
    done
    return 1
}

# Build pinned apps list
APPS=""
declare -A SHOWN
while IFS= read -r line; do
    [ -z "$line" ] && continue
    [[ "$line" =~ ^# ]] && continue
    local_info=$(resolve_desktop "$line") || continue
    IFS='|' read -r pname picon _pfile <<< "$local_info"
    [ -n "${SHOWN[$pname]}" ] && continue
    SHOWN[$pname]=1
    if [ -n "$picon" ]; then
        APPS+="$pname\0icon\x1f$picon\n"
    else
        APPS+="$pname\n"
    fi
done < "$PIN_FILE"

# System entries (always present — nerd font icons for consistent mono look)
APPS+="󰀻 App Drawer\n"
APPS+="󰒓 System Settings\n"
APPS+="󰐥 Power Options"

# Launch fuzzel
CHOICE=$(echo -e "$APPS" | tfuzzel -d -p " 󰀻 Tebian | " --width 30)

[ -z "$CHOICE" ] && exit 0

# Handle system entries
case "$CHOICE" in
    *"App Drawer"*)
        tebian-drawer &
        exit 0
        ;;
    *"System Settings"*)
        tebian-settings
        exit 0
        ;;
    *"Power Options"*)
        tebian-settings --power
        exit 0
        ;;
esac

# Find and launch the selected pinned app
for dir in $DESKTOP_DIRS; do
    [ -d "$dir" ] || continue
    for desktop in "$dir"/*.desktop; do
        [ -f "$desktop" ] || continue
        if grep -qxF "Name=$CHOICE" "$desktop" 2>/dev/null; then
            exec_cmd=$(grep -m1 "^Exec=" "$desktop" | cut -d= -f2- | sed 's/ %[fFuUdDnNickvm]//g')
            swaymsg exec -- "$exec_cmd"
            exit 0
        fi
    done
done

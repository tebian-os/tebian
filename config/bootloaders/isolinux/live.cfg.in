label live-normal
  menu label Tebian OS
  menu default
  linux /live/vmlinuz
  append boot=live components toram quiet splash loglevel=0 vt.global_cursor_default=0 cfg80211.ieee80211_regdom=00
  initrd /live/initrd.img

label live-failsafe
  menu label Tebian OS (safe graphics)
  linux /live/vmlinuz
  append boot=live components toram nomodeset cfg80211.ieee80211_regdom=00
  initrd /live/initrd.img
